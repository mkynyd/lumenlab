// LumenLab — Database Schema
// PostgreSQL + pgvector for AI experiment workbench & review system

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Core models (preserved from original)
// ============================================================

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String
  name                String?
  accessStatus        String   @default("active")
  credentialProfileId String?
  planTier            String   @default("premium") // free | pro | premium
  planCredits         Int      @default(0)         // 当前周期总信用点额度；0 表示 A 测期间不限制
  creditsUsed         Int      @default(0)         // 当前周期已用信用点
  cycleStartedAt      DateTime @default(now())     // 当前 30 天周期开始时间
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  apiKeys             ApiKey[]
  conversations       Conversation[]
  projects            Project[]
  files               FileAsset[]
  chunks              DocumentChunk[]
  artifacts           Artifact[]
  documentConversions DocumentConversion[]
  tokenUsages         TokenUsage[]
  credentialProfile   CredentialProfile?      @relation(fields: [credentialProfileId], references: [id], onDelete: SetNull)
  redemption          RegistrationRedemption?
  profilePrompt       String?

  @@index([email])
  @@index([credentialProfileId])
  @@index([accessStatus])
}

model ApiKey {
  id           String   @id @default(cuid())
  userId       String
  provider     String   @default("deepseek")
  encryptedKey String // AES-256-GCM encrypted blob (base64:tag:ciphertext)
  keyPrefix    String // e.g., "sk-****a1b2" for display
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

// ============================================================
// Alpha registration and centrally managed provider access
// ============================================================

model CredentialProfile {
  id         String   @id @default(cuid())
  externalId String   @unique
  name       String
  status     String   @default("active")
  version    Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  credentials ProviderCredential[]
  codes       RegistrationCode[]
  users       User[]

  @@index([status])
}

model ProviderCredential {
  id                  String   @id @default(cuid())
  externalId          String   @unique
  credentialProfileId String
  provider            String
  encryptedKey        String
  keyPrefix           String
  status              String   @default("active")
  validatedAt         DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  credentialProfile CredentialProfile @relation(fields: [credentialProfileId], references: [id], onDelete: Cascade)

  @@unique([credentialProfileId, provider])
  @@index([credentialProfileId])
  @@index([provider, status])
}

model RegistrationCode {
  id                  String    @id @default(cuid())
  externalId          String    @unique
  credentialProfileId String
  label               String
  codeDigest          String    @unique
  codeHint            String
  status              String    @default("active")
  maxRedemptions      Int
  redemptionCount     Int       @default(0)
  expiresAt           DateTime?
  publishedVersion    Int
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  credentialProfile CredentialProfile        @relation(fields: [credentialProfileId], references: [id], onDelete: Restrict)
  redemptions       RegistrationRedemption[]

  @@index([credentialProfileId])
  @@index([status, expiresAt])
}

model RegistrationRedemption {
  id        String   @id @default(cuid())
  codeId    String
  userId    String   @unique
  createdAt DateTime @default(now())

  code RegistrationCode @relation(fields: [codeId], references: [id], onDelete: Restrict)
  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([codeId])
}

model RegistrationPublication {
  id             String   @id @default(cuid())
  externalId     String   @unique
  version        Int      @unique
  payloadDigest  String
  sourceIssuedAt DateTime
  appliedAt      DateTime @default(now())

  @@index([appliedAt])
}

model RegistrationSyncNonce {
  id        String   @id @default(cuid())
  nonce     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Conversation {
  id                 String   @id @default(cuid())
  userId             String
  projectId          String? // nullable — existing chats without project remain valid
  title              String   @default("New Chat")
  model              String   @default("deepseek-v4-pro")
  modelLock          String?
  thinkingEnabled    Boolean  @default(true)
  activeSkillId      String?
  activeSkillVersion String?
  activeSkillSource  String?
  activeSkillStatus  String?
  skillDisabled      Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  project            Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages           Message[]
  artifacts          Artifact[]
  conversationSkills ConversationSkill[]
  tokenUsages        TokenUsage[]

  @@index([userId])
  @@index([projectId])
  @@index([activeSkillId])
}

model Message {
  id               String   @id @default(cuid())
  conversationId   String
  role             String // "user" | "assistant" | "system"
  content          String
  reasoningContent String? // thinking mode reasoning_content
  tokenCount       Int?
  provider         String? // actual provider that produced this assistant response
  cacheHitTokens   Int?
  cacheMissTokens  Int?
  sources          Json?
  subtype          String? // e.g. "context-summary"
  metadata         Json?  // 压缩摘要的额外信息
  createdAt        DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  artifacts    Artifact[]
  tokenUsage   TokenUsage?

  @@index([conversationId])
}

model TokenUsage {
  id                    String   @id @default(cuid())
  userId                String
  conversationId        String?
  messageId             String?  @unique
  model                 String
  provider              String
  inputCacheHitTokens   Int      @default(0)
  inputCacheMissTokens  Int      @default(0)
  outputTokens          Int      @default(0)
  totalTokens           Int      @default(0)
  creditsConsumed       Int      @default(0)
  createdAt             DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message      Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([conversationId])
}

// ============================================================
// New models (Task 1 — AI Experiment Workbench)
// ============================================================

model Project {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String?
  type            String   @default("general") // experiment, review, coding, general
  defaultModel    String   @default("deepseek-v4-pro")
  thinkingEnabled Boolean  @default(true)
  systemPrompt    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  files         FileAsset[]
  chunks        DocumentChunk[]
  artifacts     Artifact[]
  projectIndex  ProjectIndex?
  quickActions  QuickAction[]

  @@index([userId])
}

model FileAsset {
  id                 String   @id @default(cuid())
  userId             String
  projectId          String?
  filename           String // sanitized storage filename
  originalName       String // original upload filename
  mimeType           String
  size               Int // bytes
  storageProvider    String   @default("local") // local, qiniu
  storagePath        String // local relative path or object storage key
  textContent        String? // parsed text content (null for images/PDFs)
  enhancedContent    String?
  enhancementStatus  String   @default("none") // none, enhancing, enhanced, stale, failed
  processingMetadata Json?
  status             String   @default("uploaded") // uploaded, parsed, failed
  category           String?
  categoryConfidence Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chunks  DocumentChunk[]
  resources FileAssetResource[]

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([category])
  @@index([storageProvider])
}

model ProjectIndex {
  id        String   @id @default(cuid())
  projectId String   @unique
  content   String
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model QuickAction {
  id        String   @id @default(cuid())
  projectId String
  title     String
  prompt    String
  isSystem  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Artifact {
  id             String   @id @default(cuid())
  userId         String
  projectId      String?
  conversationId String?
  messageId      String?
  title          String
  type           String
  format         String   @default("markdown")
  content        String
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message      Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)
  references   ReferenceListItem[]

  @@index([userId])
  @@index([projectId])
  @@index([conversationId])
  @@index([messageId])
  @@index([type])
}

model DocumentConversion {
  id                    String   @id @default(cuid())
  userId                String
  title                 String
  originalName          String
  markdownContent       String
  status                String   @default("completed")
  fileSize              Int?
  pageCount             Int?
  metadata              Json?
  exportStorageProvider String?
  exportStoragePath     String?
  exportSize            Int?
  exportGeneratedAt     DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user   User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets DocumentConversionAsset[]

  @@index([userId])
  @@index([userId, createdAt])
}

model DocumentConversionAsset {
  id              String   @id @default(cuid())
  conversionId    String
  relativePath    String
  mimeType        String
  size            Int
  storageProvider String
  storagePath     String
  createdAt       DateTime @default(now())

  conversion DocumentConversion @relation(fields: [conversionId], references: [id], onDelete: Cascade)

  @@unique([conversionId, relativePath])
  @@index([conversionId])
  @@index([storageProvider])
}

model FileAssetResource {
  id              String   @id @default(cuid())
  fileAssetId     String
  relativePath    String
  mimeType        String
  size            Int
  storageProvider String
  storagePath     String
  createdAt       DateTime @default(now())

  fileAsset FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)

  @@unique([fileAssetId, relativePath])
  @@index([fileAssetId])
  @@index([storageProvider])
}

model DocumentChunk {
  id          String  @id @default(cuid())
  userId      String
  projectId   String?
  fileAssetId String?

  title       String?
  content     String
  contentHash String?
  chunkIndex  Int     @default(0)
  tokenCount  Int?
  metadata    Json?
  mediaUrls   String[] @default([])

  // pgvector embedding — 1024 dimensions (qwen3-vl-embedding fusion mode)
  embedding Unsupported("vector(1024)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileAsset FileAsset? @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([fileAssetId])
  @@index([contentHash])
}

model QueryEmbeddingCache {
  id         String   @id @default(cuid())
  userId     String
  namespace  String
  promptHash String
  promptText String
  embedding  Unsupported("vector(1024)")
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@unique([namespace, promptHash])
  @@index([userId])
  @@index([namespace])
  @@index([expiresAt])
}

model SemanticResponseCache {
  id           String   @id @default(cuid())
  userId       String
  namespace    String
  promptHash   String
  responseType String
  responseJson String
  embedding    Unsupported("vector(1024)")
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([userId])
  @@index([namespace])
  @@index([responseType])
  @@index([expiresAt])
}

// ============================================================
// Agent mode — Tool / Skill registries, executions, approvals, audit
// ============================================================

model SkillPackage {
  id                    String   @id @default(cuid())
  skillId               String
  version               String
  description           String
  instructionsRef       String
  allowedTools          String[]
  allowedRiskLevel      String[]
  requiredScopes        String[]
  defaultApprovalPolicy String
  inputContract         Json
  outputContract        Json
  dataHandlingPolicy    Json
  isSystem              Boolean  @default(false)
  installedByUserId     String?
  createdAt             DateTime @default(now())

  @@unique([skillId, version])
  @@index([isSystem, skillId])
}

model ConversationSkill {
  id             String    @id @default(cuid())
  conversationId String
  skillId        String
  version        String
  source         String?
  statusAtActivation String?
  confidence     Float?
  reason         String?
  missingInfo    Json?
  activatedAt    DateTime  @default(now())
  deactivatedAt  DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, activatedAt])
  @@index([skillId, version])
}

model ToolDefinition {
  id                    String   @id @default(cuid())
  toolId                String   @unique
  name                  String
  description           String
  inputSchema           Json
  outputSchema          Json
  riskLevel             String
  isReadOnly            Boolean
  hasExternalSideEffect Boolean
  isReversible          Boolean
  containsSensitiveData Boolean
  requiresNetwork       Boolean
  estimatedCost         String?
  defaultApprovalMode   String
  allowedSkillIds       String[]
  auditLevel            String
  isSystem              Boolean  @default(false)
  installedByUserId     String?
  createdAt             DateTime @default(now())
}

model ToolExecution {
  id                  String    @id @default(cuid())
  conversationId      String
  userId              String
  skillId             String?
  skillVersion        String?
  toolId              String
  normalizedArguments Json
  argumentsHash       String
  riskLevel           String
  status              String
  approvalSnapshot    Json?
  approvalTokenHash   String?
  approvalScope       String?
  createdAt           DateTime  @default(now())
  expiresAt           DateTime?
  approvedAt          DateTime?
  executedAt          DateTime?
  completedAt         DateTime?
  resultSummary       Json?
  errorSummary        Json?
  auditMetadata       Json?

  @@index([conversationId, createdAt])
  @@index([userId, status])
  @@index([status, expiresAt])
}

model ApprovalToken {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  userId         String
  conversationId String
  toolId         String
  argumentsHash  String
  requestId      String
  createdAt      DateTime  @default(now())
  expiresAt      DateTime
  consumedAt     DateTime?

  @@index([tokenHash])
  @@index([userId, expiresAt])
}

model AgentAuditLog {
  id              String   @id @default(cuid())
  userId          String
  conversationId  String?
  toolExecutionId String?
  skillId         String?
  toolId          String?
  eventType       String
  severity        String
  payload         Json
  ip              String?
  userAgent       String?
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([conversationId, createdAt])
  @@index([toolExecutionId])
}

model UserToolPreference {
  id           String   @id @default(cuid())
  userId       String
  toolId       String
  approvalMode String
  scope        String
  updatedAt    DateTime @updatedAt

  @@unique([userId, toolId])
}

// ============================================================
// Citation Manager — Reference store
// ============================================================

model Reference {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  doi       String?
  arxivId   String?
  title     String
  authors   String[]
  year      Int?
  venue     String?
  url       String?
  rawMeta   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listItems ReferenceListItem[]

  @@index([userId])
  @@index([projectId])
  @@index([arxivId])
  @@index([doi])
}

model ReferenceListItem {
  id           String   @id @default(cuid())
  artifactId   String
  referenceId  String
  orderIndex   Int
  format       String   @default("apa")
  inlineMarker String?
  createdAt    DateTime @default(now())

  artifact  Artifact  @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  reference Reference @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@unique([artifactId, referenceId])
  @@index([artifactId])
  @@index([referenceId])
}
