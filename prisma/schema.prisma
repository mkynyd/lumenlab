// LumenLab — Database Schema
// PostgreSQL + pgvector for AI experiment workbench & review system

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Core models (preserved from original)
// ============================================================

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String
  name                String?
  accessStatus        String   @default("active")
  credentialProfileId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  apiKeys             ApiKey[]
  conversations       Conversation[]
  projects            Project[]
  files               FileAsset[]
  chunks              DocumentChunk[]
  artifacts           Artifact[]
  documentConversions DocumentConversion[]
  credentialProfile   CredentialProfile?      @relation(fields: [credentialProfileId], references: [id], onDelete: SetNull)
  redemption          RegistrationRedemption?
  profileRoles        UserProfileRole[]

  @@index([email])
  @@index([credentialProfileId])
  @@index([accessStatus])
}

model ApiKey {
  id           String   @id @default(cuid())
  userId       String
  provider     String   @default("deepseek")
  encryptedKey String // AES-256-GCM encrypted blob (base64:tag:ciphertext)
  keyPrefix    String // e.g., "sk-****a1b2" for display
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

// ============================================================
// Alpha registration and centrally managed provider access
// ============================================================

model CredentialProfile {
  id         String   @id @default(cuid())
  externalId String   @unique
  name       String
  status     String   @default("active")
  version    Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  credentials ProviderCredential[]
  codes       RegistrationCode[]
  users       User[]

  @@index([status])
}

model ProviderCredential {
  id                  String   @id @default(cuid())
  externalId          String   @unique
  credentialProfileId String
  provider            String
  encryptedKey        String
  keyPrefix           String
  status              String   @default("active")
  validatedAt         DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  credentialProfile CredentialProfile @relation(fields: [credentialProfileId], references: [id], onDelete: Cascade)

  @@unique([credentialProfileId, provider])
  @@index([credentialProfileId])
  @@index([provider, status])
}

model RegistrationCode {
  id                  String    @id @default(cuid())
  externalId          String    @unique
  credentialProfileId String
  label               String
  codeDigest          String    @unique
  codeHint            String
  status              String    @default("active")
  maxRedemptions      Int
  redemptionCount     Int       @default(0)
  expiresAt           DateTime?
  publishedVersion    Int
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  credentialProfile CredentialProfile        @relation(fields: [credentialProfileId], references: [id], onDelete: Restrict)
  redemptions       RegistrationRedemption[]

  @@index([credentialProfileId])
  @@index([status, expiresAt])
}

model RegistrationRedemption {
  id        String   @id @default(cuid())
  codeId    String
  userId    String   @unique
  createdAt DateTime @default(now())

  code RegistrationCode @relation(fields: [codeId], references: [id], onDelete: Restrict)
  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([codeId])
}

model RegistrationPublication {
  id             String   @id @default(cuid())
  externalId     String   @unique
  version        Int      @unique
  payloadDigest  String
  sourceIssuedAt DateTime
  appliedAt      DateTime @default(now())

  @@index([appliedAt])
}

model RegistrationSyncNonce {
  id        String   @id @default(cuid())
  nonce     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Conversation {
  id              String   @id @default(cuid())
  userId          String
  projectId       String? // nullable — existing chats without project remain valid
  title           String   @default("New Chat")
  model           String   @default("deepseek-v4-pro")
  modelLock       String?
  thinkingEnabled Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages  Message[]
  artifacts Artifact[]
  intent    ConversationIntent?

  @@index([userId])
  @@index([projectId])
}

model Message {
  id               String   @id @default(cuid())
  conversationId   String
  role             String // "user" | "assistant" | "system"
  content          String
  reasoningContent String? // thinking mode reasoning_content
  tokenCount       Int?
  provider         String? // actual provider that produced this assistant response
  cacheHitTokens   Int?
  cacheMissTokens  Int?
  createdAt        DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  artifacts    Artifact[]

  @@index([conversationId])
}

// ============================================================
// New models (Task 1 — AI Experiment Workbench)
// ============================================================

model Project {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String?
  type            String   @default("general") // experiment, review, coding, general
  defaultModel    String   @default("deepseek-v4-pro")
  thinkingEnabled Boolean  @default(true)
  systemPrompt    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  files         FileAsset[]
  chunks        DocumentChunk[]
  artifacts     Artifact[]
  projectIndex  ProjectIndex?
  quickActions  QuickAction[]
  projectRoles  ProjectRole[]

  @@index([userId])
}

model FileAsset {
  id                 String   @id @default(cuid())
  userId             String
  projectId          String?
  filename           String // sanitized storage filename
  originalName       String // original upload filename
  mimeType           String
  size               Int // bytes
  storageProvider    String   @default("local") // local, qiniu
  storagePath        String // local relative path or object storage key
  textContent        String? // parsed text content (null for images/PDFs)
  enhancedContent    String?
  enhancementStatus  String   @default("none") // none, enhancing, enhanced, stale, failed
  processingMetadata Json?
  status             String   @default("uploaded") // uploaded, parsed, failed
  category           String?
  categoryConfidence Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chunks  DocumentChunk[]
  resources FileAssetResource[]

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([category])
  @@index([storageProvider])
}

model ProjectIndex {
  id        String   @id @default(cuid())
  projectId String   @unique
  content   String
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model QuickAction {
  id        String   @id @default(cuid())
  projectId String
  title     String
  prompt    String
  isSystem  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Artifact {
  id             String   @id @default(cuid())
  userId         String
  projectId      String?
  conversationId String?
  messageId      String?
  title          String
  type           String
  format         String   @default("markdown")
  content        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message      Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([conversationId])
  @@index([messageId])
  @@index([type])
}

model DocumentConversion {
  id                    String   @id @default(cuid())
  userId                String
  title                 String
  originalName          String
  markdownContent       String
  status                String   @default("completed")
  fileSize              Int?
  pageCount             Int?
  metadata              Json?
  exportStorageProvider String?
  exportStoragePath     String?
  exportSize            Int?
  exportGeneratedAt     DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user   User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets DocumentConversionAsset[]

  @@index([userId])
  @@index([userId, createdAt])
}

model DocumentConversionAsset {
  id              String   @id @default(cuid())
  conversionId    String
  relativePath    String
  mimeType        String
  size            Int
  storageProvider String
  storagePath     String
  createdAt       DateTime @default(now())

  conversion DocumentConversion @relation(fields: [conversionId], references: [id], onDelete: Cascade)

  @@unique([conversionId, relativePath])
  @@index([conversionId])
  @@index([storageProvider])
}

model FileAssetResource {
  id              String   @id @default(cuid())
  fileAssetId     String
  relativePath    String
  mimeType        String
  size            Int
  storageProvider String
  storagePath     String
  createdAt       DateTime @default(now())

  fileAsset FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)

  @@unique([fileAssetId, relativePath])
  @@index([fileAssetId])
  @@index([storageProvider])
}

model DocumentChunk {
  id          String  @id @default(cuid())
  userId      String
  projectId   String?
  fileAssetId String?

  title       String?
  content     String
  contentHash String?
  chunkIndex  Int     @default(0)
  tokenCount  Int?
  metadata    Json?

  // pgvector embedding — 1024 dimensions (Aliyun Bailian text-embedding-v4)
  embedding Unsupported("vector(1024)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileAsset FileAsset? @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([fileAssetId])
  @@index([contentHash])
}

// ============================================================
// User Identity & Role Classification (UserRole system)
// ============================================================

model UserRole {
  id                     String   @id @default(cuid())
  key                    String   @unique
  label                  String
  description            String?
  applicableModes        String[] // ["review", "experiment", "coding", "general"]
  classifierHints        Json     // { keywords, positiveExamples, negativeExamples, priorityBoost }
  systemPromptAddition   String   // Identity injection text
  recommendedQuickActions Json?    // [{ title, prompt }]
  priority               Int      @default(0)
  isActive               Boolean  @default(true)
  version                Int      @default(1)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  profileRoles UserProfileRole[]
  projectRoles ProjectRole[]
  intentRoles  ConversationIntent[]

  @@index([isActive, priority])
}

model UserProfileRole {
  id          String   @id @default(cuid())
  userId      String
  roleId      String
  isPrimary   Boolean  @default(false)
  source      String   @default("manual") // "manual" | "stepper" | "conversation"
  confidence  Float?
  confirmedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role UserRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
}

model ProjectRole {
  id             String   @id @default(cuid())
  projectId      String
  roleId         String
  mode           String   // "review" | "experiment" | "coding" | "general"
  classification Json     // Full DeepSeek classification result
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role    UserRole @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@index([projectId])
}

model ConversationIntent {
  id              String    @id @default(cuid())
  conversationId  String    @unique
  roleId          String?
  mode            String?
  classification  Json?     // Intent classification result
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role         UserRole?    @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@index([conversationId])
}
