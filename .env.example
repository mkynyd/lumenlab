# PostgreSQL (pgvector)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_workspace?schema=public"

# Optional shared cache/rate limit store. The app falls back to memory when unavailable.
REDIS_URL="redis://localhost:6379"

# Cache experiments are intentionally disabled until baseline metrics are collected.
CACHE_EXPERIMENT_PROMPT_REORDER="false"
CACHE_EXPERIMENT_REORDER_STRATEGY="rag-to-last-user"
CACHE_EXPERIMENT_MINIMAX_ACTIVE="false"

# Auth — generate via: openssl rand -base64 32
AUTH_SECRET="please-change-this"

# Encryption Key for API Key storage — 64 hex chars (32 bytes)
# Generate via: openssl rand -hex 32
ENCRYPTION_KEY="please-generate-a-64-char-hex-string"

# Alpha registration codes — generate each secret independently.
REGISTRATION_CODE_PEPPER="generate-with-openssl-rand-base64-48"
REGISTRATION_SYNC_SECRET="same-random-secret-as-course-ai-regadmin"
REGISTRATION_SYNC_PRIVATE_KEY_BASE64="base64-encoded-RSA-private-key-PEM"

# DeepSeek API
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# App
AUTH_URL="https://lab.mkynstudio.top"
NEXT_PUBLIC_APP_NAME="AI 实验工作台"
